# 사용자 설정 (필수)
OWNER_NAME=여기에_본인_이름_입력

# AI 모델 API 키
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력
OPENAI_API_KEY=sk-proj-여기에_API_키_입력
GOOGLE_API_KEY=AIzaSy여기에_API_키_입력
PERPLEXITY_API_KEY=pplx-여기에_API_키_입력

# Gmail 발송 (선택)
GMAIL_ADDRESS=여기에_이메일_입력
GMAIL_APP_PASSWORD=여기에_앱_비밀번호_입력

# 디스코드 알림 (선택)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Meta Ads Library API (필수 — 광고 분석 기능)
META_ACCESS_TOKEN=여기에_토큰_입력
INSTAGRAM_BUSINESS_ACCOUNT_ID=여기에_계정ID_입력

# Cloudflare 배포 (선택사항)
CLOUDFLARE_API_TOKEN=여기에_토큰_입력
CLOUDFLARE_ACCOUNT_ID=여기에_계정ID_입력
CF_PROJECT_NAME=your-project-name

# 크론 모니터링 (선택)
PROJECT_URL=https://your-project.cloudflare.app

# GitHub MCP (선택)
GITHUB_PERSONAL_ACCESS_TOKEN=여기에_토큰_입력

# Sentry 에러 트래킹 (선택)
SENTRY_AUTH_TOKEN=여기에_토큰_입력

# Supabase DB (선택)
SUPABASE_URL=여기에_프로젝트_URL
SUPABASE_SERVICE_ROLE_KEY=여기에_서비스_롤_키
