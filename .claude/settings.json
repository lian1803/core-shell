{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/hkyou/Documents/work_youns/core-shell/.claude/hooks/pre_tool_safety.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: Claude 작업 저장\" && git push 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "GitHub에 저장 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.stdout // \"\"' | grep -q 'Aliased: https://lian-dash.vercel.app' && \"/c/Users/hkyou/Documents/work_youns/core-shell/lian_company/venv/Scripts/python.exe\" \"/c/Users/hkyou/Documents/work_youns/core-shell/lian_company/auto_visual_review.py\" > /dev/null 2>&1 & true",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
