{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/lian1/Documents/Work/core/.claude/hooks/pre_tool_safety.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: Claude 작업 저장\" && git push 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "GitHub에 저장 중..."
          }
        ]
      }
    ]
  }
}
