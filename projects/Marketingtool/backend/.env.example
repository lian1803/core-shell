# Backend Environment Variables
# Set actual values in .env.local

# ===== Server Settings =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
PYTHON_ENV=development

# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/marketingtool

# ===== Naver API =====
# Get these from https://developers.naver.com/
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
NAVER_DATA_LAB_KEY=your_naver_data_lab_key_here

# ===== Keyword Tool API =====
KEYWORD_TOOL_API_KEY=

# ===== PPT Template =====
PPT_TEMPLATE_PATH=./templates
PPT_OUTPUT_PATH=./output
