// prisma/schema.prisma
// Instauto - 소상공인 인스타그램 자동화 서비스 데이터 모델

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum PlanType {
  BASIC // 19,900원/월, 재생성 3회/일
  PRO   // 39,900원/월, 재생성 10회/일
}

enum SubscriptionStatus {
  TRIAL           // 무료 체험 중 (14일, 리뷰 시 +7일)
  ACTIVE          // 유료 구독 중
  PAST_DUE        // 결제 실패 (7일 유예)
  CANCELED        // 구독 취소됨
  EXPIRED         // 체험 만료 또는 결제 실패 만료
}

enum ContentStatus {
  GENERATING      // AI 생성 중
  READY           // 생성 완료, 발행 대기
  PUBLISHED       // 다운로드/복사 완료 (발행됨으로 간주)
  FAILED          // 생성 실패
}

enum PaymentStatus {
  PENDING         // 결제 대기
  DONE            // 결제 완료
  CANCELED        // 결제 취소
  FAILED          // 결제 실패
}

// =============================================================================
// Models
// =============================================================================

// 유저 (Supabase Auth와 1:1 매핑)
model User {
  id            String        @id                   // Supabase Auth uid와 동일값 사용
  email         String        @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  shop          Shop?
  subscription  Subscription?
  contents      Content[]
  payments      Payment[]
}

// 가게 정보 (온보딩에서 수집)
model Shop {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String                          // 가게 이름
  industry        String    @default("cafe")      // MVP: "cafe" 고정
  vibeKeywords    String[]                        // 분위기 키워드 3개 배열. 예: ["아늑한", "감성적", "모던"]
  representMenus  String[]                        // 대표 메뉴 최대 3개. 예: ["아메리카노", "크로플"]

  // Instagram 연동 정보 (Phase 1.0에서는 미사용, 향후 확장용)
  igUserId        String?                         // Instagram 비즈니스 계정 ID
  igUsername      String?                         // @계정명
  igAccessToken   String?                         // 장기 액세스 토큰 (AES-256-GCM 암호화 저장)
  igTokenExpiry   DateTime?                       // 토큰 만료일

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

// 구독 정보
model Subscription {
  id                  String              @id @default(uuid())
  userId              String              @unique
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                PlanType            @default(BASIC)
  status              SubscriptionStatus  @default(TRIAL)

  // 무료 체험 기간
  trialStartAt        DateTime            @default(now())
  trialEndAt          DateTime                              // trialStartAt + 14일 (기본)

  // 리뷰 연장 정보
  trialExtended       Boolean             @default(false)   // 리뷰로 연장했는지 여부
  trialExtendedAt     DateTime?                             // 연장 시점
  reviewUrl           String?                               // 리뷰 URL (검증용)

  // 유료 구독 기간
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?

  // 토스페이먼츠 빌링 정보
  tossBillingKey      String?                               // 빌링키 (암호화 저장)
  tossCustomerKey     String?                               // 토스 고객 키 (uuid)

  // 취소 정보
  canceledAt          DateTime?
  cancelReason        String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([trialEndAt])
}

// 콘텐츠 (매일 자동 생성되는 인스타 포스트)
model Content {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 생성된 콘텐츠
  caption           String                                  // AI 생성 캡션 (해시태그 포함)
  editedCaption     String?                                 // 사용자 수정 캡션
  imageUrl          String                                  // 원본 이미지 URL (Supabase Storage)
  thumbnailUrl      String?                                 // 썸네일 WebP URL (512x512)

  // 재생성 관련
  regenerateCount   Int           @default(0)              // 오늘 재생성 횟수
  lastRegenerateAt  DateTime?                              // 마지막 재생성 시점

  // 상태
  status            ContentStatus @default(GENERATING)
  targetDate        DateTime      @db.Date                 // 해당 콘텐츠의 타겟 날짜 (YYYY-MM-DD)

  // 발행 정보
  publishedAt       DateTime?                              // 다운로드/복사 완료 시점

  // 메타 정보
  promptUsed        String?       @db.Text                 // 이미지 생성에 사용된 프롬프트
  captionPromptUsed String?       @db.Text                 // 캡션 생성에 사용된 프롬프트

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([userId, targetDate])                           // 유저당 하루에 하나의 콘텐츠
  @@index([userId])
  @@index([status])
  @@index([targetDate])
}

// 결제 내역
model Payment {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 토스페이먼츠 정보
  tossPaymentKey    String?       @unique                  // 토스 결제 키
  tossOrderId       String        @unique                  // 주문 ID (우리가 생성)

  // 결제 정보
  amount            Int                                    // 결제 금액
  plan              PlanType                               // 결제한 플랜
  status            PaymentStatus @default(PENDING)

  // 빌링 (정기 결제)
  isBilling         Boolean       @default(false)          // 정기 결제 여부
  billingCycle      Int?                                   // 몇 번째 정기 결제인지

  // 결제 일시
  paidAt            DateTime?
  canceledAt        DateTime?
  failedAt          DateTime?
  failReason        String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([tossOrderId])
}
