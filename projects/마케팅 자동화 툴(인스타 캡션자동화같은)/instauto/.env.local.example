# =============================================================================
# Instauto 환경변수 설정
# =============================================================================
# 이 파일을 복사하여 .env.local 파일을 만들고 실제 값으로 채워주세요.
#
#   cp .env.local.example .env.local
#
# 각 변수 발급 방법은 DEPLOY.md 파일을 참조하세요.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (필수)
# -----------------------------------------------------------------------------
# 발급 위치: https://supabase.com/dashboard/project/[YOUR-PROJECT]/settings/api
#
# Project URL - 프로젝트 기본 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key - 클라이언트에서 사용하는 공개 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key - 서버에서만 사용하는 관리자 키 (절대 클라이언트에 노출 금지!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# Database - Supabase PostgreSQL (필수)
# -----------------------------------------------------------------------------
# 발급 위치: https://supabase.com/dashboard/project/[YOUR-PROJECT]/settings/database
#            > Connection string > URI 탭
#
# Transaction mode (pgBouncer) - Prisma 기본 연결용
# [YOUR-PASSWORD]를 실제 데이터베이스 비밀번호로 변경하세요
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session mode (Direct) - Prisma migrate용
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres


# -----------------------------------------------------------------------------
# OpenAI (필수)
# -----------------------------------------------------------------------------
# 발급 위치: https://platform.openai.com/api-keys
#
# GPT-4o (캡션 생성) 및 DALL-E 3 (이미지 생성) 모델 사용
# 신규 계정은 결제 정보 등록 후 사용 가능
OPENAI_API_KEY=sk-proj-...


# -----------------------------------------------------------------------------
# 토스페이먼츠 (Phase 1.1 - 결제 기능)
# -----------------------------------------------------------------------------
# 발급 위치: https://developers.tosspayments.com/
#            > 내 개발정보 > API 키
#
# 테스트 환경에서는 test_ 접두사 키 사용
# 실제 결제 시 live_ 접두사 키로 변경 (사업자 인증 필요)

# 시크릿 키 (서버용) - test_sk_... 또는 live_sk_...
TOSS_SECRET_KEY=test_sk_...

# 클라이언트 키 (프론트용) - test_ck_... 또는 live_ck_...
TOSS_CLIENT_KEY=test_ck_...

# 웹훅 시크릿 (결제 상태 변경 알림용)
# 발급 위치: 토스페이먼츠 개발자센터 > 웹훅 > 웹훅 등록
TOSS_WEBHOOK_SECRET=your-webhook-secret


# -----------------------------------------------------------------------------
# Resend (이메일 알림)
# -----------------------------------------------------------------------------
# 발급 위치: https://resend.com/api-keys
#
# 무료 플랜: 월 3,000건 / 일 100건
RESEND_API_KEY=re_...

# 발신 이메일 주소
# 도메인 인증 전: onboarding@resend.dev 만 사용 가능 (테스트용)
# 도메인 인증 후: 원하는 주소 사용 가능 (예: noreply@instauto.kr)
FROM_EMAIL=Instauto <onboarding@resend.dev>


# -----------------------------------------------------------------------------
# 암호화 키 (필수)
# -----------------------------------------------------------------------------
# Instagram Access Token 등 민감 정보를 AES-256-GCM으로 암호화할 때 사용
#
# 생성 방법 (터미널):
#   openssl rand -base64 32
#
# 또는 PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#
# 한 번 설정 후 변경하면 기존 암호화 데이터를 복호화할 수 없으니 주의!
ENCRYPTION_KEY=your-32-character-random-base64-string==


# -----------------------------------------------------------------------------
# Cron Job 인증 (필수)
# -----------------------------------------------------------------------------
# Vercel Cron Job이 API를 호출할 때 사용하는 시크릿
# 이 값이 없으면 누구나 Cron API를 호출할 수 있어 보안 위험
#
# 생성 방법 (터미널):
#   openssl rand -hex 32
#
# 또는 PowerShell:
#   -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Maximum 16) })
CRON_SECRET=your-64-character-random-hex-string


# -----------------------------------------------------------------------------
# 앱 URL (필수)
# -----------------------------------------------------------------------------
# 이메일 내 링크, OAuth 콜백 등에 사용
#
# 로컬 개발: http://localhost:3000
# 프로덕션: https://your-domain.com (Vercel 기본 도메인 또는 커스텀 도메인)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 개발 환경 설정
# -----------------------------------------------------------------------------
# development | production
# Vercel 배포 시 자동으로 production으로 설정됨
NODE_ENV=development


# =============================================================================
# Phase 1.1 추가 환경변수 (인스타그램 자동 발행 시 필요)
# =============================================================================
# 현재는 미사용. 인스타그램 연동 기능 추가 시 설정 필요

# Meta (Facebook/Instagram) App 설정
# 발급 위치: https://developers.facebook.com/apps/
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
