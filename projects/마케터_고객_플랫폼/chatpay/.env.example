# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chatpay"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"

# PG Encryption Key (openssl rand -hex 32)
PG_ENCRYPT_KEY="your-64-char-hex-string"

# Resend (Email)
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="ChatPay <noreply@chatpay.kr>"

# URLs
APP_URL="http://localhost:3001"
API_URL="http://localhost:3000"
WEB_URL="http://localhost:3001"

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
