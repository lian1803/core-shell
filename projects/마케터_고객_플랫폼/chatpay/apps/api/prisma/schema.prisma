generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 인증 / 계정 ────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace         Workspace?
}

// ─── 워크스페이스 ────────────────────────────────────────────────

model Workspace {
  id              String      @id @default(cuid())
  name            String
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])

  widgetToken     String      @unique @default(cuid())
  pgProvider      PgProvider? @default(NONE)
  pgKeyEncrypted  String?

  isActive        Boolean     @default(true)

  chatRooms       ChatRoom[]
  paymentLinks    PaymentLink[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum PgProvider {
  NONE
  KAKAOPAY
  TOSS
}

// ─── 채팅 ────────────────────────────────────────────────────────

model ChatRoom {
  id           String        @id @default(cuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])

  visitorId    String        // localStorage 기반 방문자 식별자
  visitorName  String        @default("방문자")
  status       RoomStatus    @default(OPEN)

  messages     Message[]
  paymentLinks PaymentLink[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  closedAt     DateTime?
}

enum RoomStatus {
  OPEN
  CLOSED
}

model Message {
  id         String      @id @default(cuid())
  roomId     String
  room       ChatRoom    @relation(fields: [roomId], references: [id])

  sender     SenderType
  content    String
  createdAt  DateTime    @default(now())
}

enum SenderType {
  MARKETER
  VISITOR
}

// ─── 결제 링크 ────────────────────────────────────────────────────

model PaymentLink {
  id           String            @id @default(cuid())
  workspaceId  String
  workspace    Workspace         @relation(fields: [workspaceId], references: [id])
  roomId       String
  room         ChatRoom          @relation(fields: [roomId], references: [id])

  productName  String
  amount       Int               // 원 단위
  pgProvider   PgProvider
  pgOrderId    String?           // PG 측 주문 ID
  pgTid        String?           // 카카오페이 tid / 토스 paymentKey
  status       PaymentStatus     @default(PENDING)

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  paidAt       DateTime?
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}
